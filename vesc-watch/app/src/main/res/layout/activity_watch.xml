<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Duty cycle circle (hero, centered) -->
    <com.vescwatch.DutyCircleView
        android:id="@+id/duty_circle"
        android:layout_width="105dp"
        android:layout_height="105dp"
        android:layout_centerInParent="true" />

    <!-- Speed (above circle, centered) -->
    <LinearLayout
        android:id="@+id/speed_block"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/duty_circle"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="2dp"
        android:orientation="horizontal"
        android:gravity="bottom">

        <TextView
            android:id="@+id/speed_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--"
            android:textColor="#FFFFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" mph"
            android:textColor="#FF9E9E9E"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />
    </LinearLayout>

    <!-- Temps (right of circle) -->
    <LinearLayout
        android:id="@+id/temp_block"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/duty_circle"
        android:layout_alignTop="@id/duty_circle"
        android:layout_alignBottom="@id/duty_circle"
        android:layout_marginStart="6dp"
        android:orientation="vertical"
        android:gravity="center_vertical|end">

        <TextView
            android:id="@+id/temp_mos_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="C:--°"
            android:textColor="#FF9E9E9E"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/temp_motor_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="M:--°"
            android:textColor="#FF9E9E9E"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/temp_batt_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="B:--°"
            android:textColor="#FF9E9E9E"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Battery + voltage (below circle) -->
    <LinearLayout
        android:id="@+id/batt_block"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/duty_circle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="2dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/batt_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textColor="#FFFFFFFF"
            android:textSize="16sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  ·  "
            android:textColor="#FF9E9E9E"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/voltage_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--V"
            android:textColor="#FF9E9E9E"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- Status text (below battery) -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/batt_block"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="0dp"
        android:text="SCANNING..."
        android:textColor="#FF9E9E9E"
        android:textSize="11sp" />

</RelativeLayout>
